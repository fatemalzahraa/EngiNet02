# ============================================
# EngiNet Backend - Environment Variables
# ============================================
# انسخ هذا الملف إلى .env وعبّئ القيم الحقيقية
# لا ترفع ملف .env على GitHub أبداً
# أضف .env إلى .gitignore

# مفتاح JWT السري - يجب أن يكون عشوائياً وطويلاً
# لتوليد مفتاح: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_strong_random_secret_key_here_min_32_chars

# قاعدة البيانات PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/enginet_db

# إعدادات البريد الإلكتروني
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_gmail_app_password

# النطاقات المسموح بها (اتركها * في التطوير فقط)
# في الإنتاج: ALLOWED_ORIGINS=https://yourapp.com,https://api.yourapp.com
ALLOWED_ORIGINS=*
